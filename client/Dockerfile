## =========================
## СТАДИЯ 1: СБОРКА (builder)
## =========================
##
## FROM — базовый образ, на котором будут выполняться команды.
## - Обязательность: ОБЯЗАТЕЛЬНО (без базового образа Dockerfile не имеет смысла).
## - Почему node:22-alpine:
##   - Node.js нужен для сборки Next.js.
##   - Alpine — компактнее по размеру, быстрее качается; иногда требует доп. системные пакеты
##     для нативных зависимостей (node-gyp), но в вашем проекте может быть не нужно.
## - AS builder — имя стадии (мультистейдж). Это ОПЦИОНАЛЬНО, но крайне полезно:
##   позволяет собрать проект в одном слое, а в рантайм-образ перенести только результат.
FROM node:22-alpine AS builder

## WORKDIR — рабочая директория внутри контейнера.
## - Обязательность: не строго обязательна, но ПРАКТИЧЕСКИ ОБЯЗАТЕЛЬНА для читаемости
##   и чтобы COPY/RUN выполнялись в ожидаемом пути.
## - Если директории нет, Docker создаст её автоматически.
WORKDIR /app

## COPY — копирует файлы из контекста сборки (папки `client/`) в контейнер.
## - Обязательность: да (иначе npm не увидит зависимости).
## - Зачем копируем ТОЛЬКО package*.json отдельно:
##   - чтобы Docker мог закешировать слой с установкой зависимостей.
##   - при изменении исходников (но без изменения зависимостей) `npm ci` не будет выполняться заново.
COPY package.json package-lock.json ./

## RUN — выполняет команду на этапе сборки образа.
## - Обязательность: да, если вы хотите собирать клиент внутри Docker.
## - npm ci:
##   - устанавливает зависимости строго по package-lock.json (детерминированно).
##   - предпочтительнее для CI/контейнеров, чем `npm install`.
RUN npm ci

## Копируем остальной код после установки зависимостей.
## - Обязательность: да (нужны исходники для `npm run build`).
## - Важно: желательно иметь `.dockerignore`, чтобы не тащить node_modules, логи и т.п.
COPY . .

## ARG — аргумент сборки (доступен только во время `docker build`).
## - Обязательность: ОПЦИОНАЛЬНО.
## - Здесь используется для проброса `NEXT_PUBLIC_API_URL` в сборку Next.js.
## - В Next.js переменные `NEXT_PUBLIC_*` "вшиваются" в бандл на этапе сборки, поэтому
##   именно ARG чаще всего корректнее, чем runtime ENV.
ARG NEXT_PUBLIC_API_URL

## ENV — переменная окружения внутри контейнера (и в этой стадии сборки).
## - Обязательность: ОПЦИОНАЛЬНО, но нужна, чтобы Next.js увидел значение при `npm run build`.
## - Мы задаём ENV из ARG (ARG сам по себе доступен, но многие тулзы читают именно ENV).
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

## Сборка production-бандла Next.js.
## - Обязательность: да, если вы хотите запускать уже собранный клиент в контейнере.
## - Предпосылка: в Next.js включён output: "standalone" (см. ниже копирование standalone).
RUN npm run build

## =========================
## СТАДИЯ 2: ЗАПУСК (runner)
## =========================
##
## В рантайм-стадии мы не устанавливаем дев-зависимости и не держим исходники,
## а переносим только результат сборки, чтобы:
## - уменьшить размер образа
## - ускорить деплой
## - сократить поверхность атаки
FROM node:22-alpine AS runner

## Рабочая директория для запуска.
WORKDIR /app

## NODE_ENV=production:
## - Обязательность: обычно да для Node/Next (включает оптимизации, отключает dev-поведение).
ENV NODE_ENV=production

## PORT:
## - Обязательность: зависит от того, как стартует сервер Next в standalone.
## - Часто используется внутри `server.js` (Next standalone) для выбора порта.
ENV PORT=3000

## Next.js output: "standalone"
## - Эти COPY предполагают, что сборка создала папки:
##   - `.next/standalone` (минимальный Node-сервер + нужные node_modules)
##   - `.next/static` (статические ассеты)
##   - `public` (публичные файлы проекта)
## - Обязательность:
##   - `standalone` — ОБЯЗАТЕЛЬНО для выбранной стратегии "node server.js".
##   - `static` и `public` — обычно ОБЯЗАТЕЛЬНО, иначе пропадут ассеты.
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

## EXPOSE — документация для образа: какой порт приложение слушает внутри контейнера.
## - Обязательность: ОПЦИОНАЛЬНО (на реальный проброс портов влияет `docker run -p` / compose `ports`).
## - Но полезно для ясности и некоторых tooling-сценариев.
EXPOSE 3000

## CMD — команда по умолчанию при запуске контейнера.
## - Обязательность: не строго обязательна (можно задавать команду при `docker run`/compose `command`),
##   но ПРАКТИЧЕСКИ ОБЯЗАТЕЛЬНА, чтобы контейнер "знал", что запускать.
## - Для Next.js standalone обычно создаётся `server.js` в корне standalone-вывода.
CMD ["node", "server.js"]

